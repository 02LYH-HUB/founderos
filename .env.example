# ── Clerk (Authentication) ──
# Get from: https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/sign-in?registered=true

# ── Database (Supabase) ──
# Get from: https://supabase.com/dashboard/project/xxx/settings/database
DATABASE_URL="postgresql://postgres.xxx:password@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres?pgbouncer=true"

# ── AI Providers ──
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
ZHIPU_API_KEY=xxx
DASHSCOPE_API_KEY=sk-xxx

# ── App URL (used by Clerk for redirects) ──
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase Auth (optional — fallback if not using Clerk) ──
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
